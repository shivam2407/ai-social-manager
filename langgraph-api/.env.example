# Copy this file to .env and fill in your values

# Required: Fernet encryption key for API key storage
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# Required: Secret key for JWT token signing (generate a random string)
JWT_SECRET_KEY=change-me-to-a-random-secret

# Optional: Comma-separated list of allowed CORS origins
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: PostgreSQL connection string (for cloud deployment, e.g. Neon)
# If not set, falls back to local SQLite for development.
# DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require
